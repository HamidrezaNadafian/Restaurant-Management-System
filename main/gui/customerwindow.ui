     <property name="styleSheet">
      <string notr="true">
QWidget {
    background-color: #1e1e24;
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;, Tahoma, Arial;
}


#menuListWidget {
    background-color: #2b2b36;
    border: none;
    border-radius: 12px;
    padding: 10px;
}
#menuListWidget::item {
    background-color: #363644;
    border-radius: 8px;
    padding: 20px;
    margin: 5px;
    color: #e0e0e0;
    font-size: 15px;
    font-weight: bold;
}
#menuListWidget::item:hover {
    background-color: #454555;
    border-left: 4px solid #ff4757;
}
#menuListWidget::item:selected {
    background-color: #ff4757;
    color: white;
}


#lblDetailName { font-size: 22px; font-weight: bold; color: #ffffff; margin-bottom: 5px; }
#lblDetailPrice { font-size: 20px; font-weight: bold; color: rgb(208, 169, 255); margin-bottom: 15px; }
#lblDetailDesc { font-size: 13px; color: #b2b2b2; background-color: #2b2b36; padding: 15px; border-radius: 8px; }
#lblDetailStatus { font-size: 14px; font-weight: bold; color: #2ed573; margin-top: 10px; }


#cartListWidget {
    background-color: #2b2b36;
    border: 1px dashed #555566;
    border-radius: 12px;
    padding: 5px;
}
#cartListWidget::item {
    background-color: #363644;
    padding: 12px;
    border-radius: 6px;
    margin-bottom: 5px;
}
#lblTotalPrice { font-size: 22px; font-weight: bold; color: #ff4757; padding: 15px 0; }


QPushButton#btnBack {
    background-color: #ff4757;
    color: white;
    font-weight: bold;
    border-radius: 8px;
    padding: 8px 15px;
}
QPushButton#btnBack:hover { background-color: #ff6b77; }

/* ۱. استایل کلی پس‌زمینه صفحه */
QDialog {
    background-color: #1a1d24; /* یک دارک ملایم و عمیق */
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;, sans-serif;
}

/* ۲. استایل لیست سمت چپ (لیست کل سفارش‌ها) */
QListWidget#listWidgetOrders {
    background-color: #222731; /* کمی روشن‌تر از بک‌گراند اصلی برای ایجاد عمق */
    border: 1px solid #2d3545;
    border-radius: 12px;
    padding: 5px;
    outline: 0; /* حذف خط فوکوس زشت دور لیست */
}

/* استایل تک‌تک آیتم‌های سفارش در سمت چپ */
QListWidget#listWidgetOrders::item {
    background-color: #2b313e;
    color: #ffffff;
    border-radius: 8px;
    padding: 12px 15px;
    margin-bottom: 8px; /* ایجاد فاصله بین هر کارت سفارش */
    font-size: 14px;
}

/* حالت هوور (وقتی موس روی کارت سفارش می‌رود) */
QListWidget#listWidgetOrders::item:hover {
    background-color: #353c4d;
    border: 1px solid #4a5568;
}

/* حالت انتخاب شده (وقتی کاربر روی سفارش کلیک کرده است) */
QListWidget#listWidgetOrders::item:selected {
    background-color: #3b82f6; /* رنگ آبی جذاب مدرن */
    color: #ffffff;
    font-weight: bold;
}


/* ۳. استایل بخش جزئیات سمت راست (بالا) */
#lblDetailName {
    font-size: 22px;
    font-weight: bold;
    color: #ffffff;
}

#lblDetailPrice {
    font-size: 18px;
    font-weight: bold;
    color: #3b82f6; /* رنگ قیمت هماهنگ با تم انتخاب */
}

#lblDetailStatus {
    font-size: 13px;
    font-weight: bold;
}


/* ۴. استایل لیست پایین سمت راست (ریز اقلام غذاها) */
QListWidget#listWidgetItems {
    background-color: #222731;
    border: 1px solid #2d3545;
    border-radius: 12px;
    padding: 10px;
    outline: 0;
}

/* استایل هر ردیف غذا */
QListWidget#listWidgetItems::item {
    color: #e2e8f0;
    padding: 10px 12px;
    border-bottom: 1px solid #2d3545; /* خط جداکننده باریک بین غذاها */
    font-size: 14px;
}

/* ردیف آخر خط جداکننده نداشته باشد */
QListWidget#listWidgetItems::item:last {
    border-bottom: none;
}

/* غیرفعال کردن افکت کلیک روی لیست غذاها (چون صرفاً نمایشی است) */
QListWidget#listWidgetItems::item:hover, 
QListWidget#listWidgetItems::item:selected {
    background-color: transparent;
    color: #e2e8f0;
}


/* ۵. جادوگری: مدرن کردن اسکرول‌بارهای زشت و قدیمی ویندوز! */
QScrollBar:vertical {
    border: none;
    background: #1a1d24;
    width: 8px;
    margin: 0px 0px 0px 0px;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #4a5568;
    min-height: 20px;
    border-radius: 4px;
}
QScrollBar::handle:vertical:hover {
    background: #718096;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}</string>
