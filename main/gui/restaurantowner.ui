QListWidget#listWidgetOwnerRestaurants {
    background-color: #1a1d24;
    border: none;
    outline: 0;
    padding: 10px;
}
QListWidget#listWidgetOwnerRestaurants::item {
    background-color: #222731;
    border: 1px solid #2d3545;
    border-radius: 12px;
    color: #ffffff;
    padding: 18px;
    margin-bottom: 12px;
}
QListWidget#listWidgetOwnerRestaurants::item:hover {
    border: 1px solid #f59e0b;
}

QListWidget#listWidgetOwnerRestaurants::item:selected {
    background-color: #2b313e; 
    border: 2px solid #f59e0b;  
    color: #ffffff;            
}

QPushButton#btnEditRestaurant, 
QPushButton#btnManageMenu, 
QPushButton#btnManageOrders {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #2a313d, stop:1 #1e232c); 
    color: #e2e8f0; 
    font-size: 13px;
    font-weight: 600; 
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;, sans-serif;
    border: 1px solid #3b4252; 
    border-radius: 8px; 
    padding: 10px 18px;
    min-height: 22px;
}


QPushButton#btnEditRestaurant:hover, 
QPushButton#btnManageMenu:hover, 
QPushButton#btnManageOrders:hover {
    background-color: #2d3545; 
    color: #ffffff; 
    border: 1px solid #f59e0b; 
}


QPushButton#btnEditRestaurant:pressed, 
QPushButton#btnManageMenu:pressed, 
QPushButton#btnManageOrders:pressed {
    background-color: #1a1f26;
    border: 1px solid #d97706;
}


