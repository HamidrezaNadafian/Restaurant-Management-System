   <property name="styleSheet">
    <string notr="true">QWidget#AdminWindow {
    background-color: #0f1115
}

QPushButton#btnAddRestaurant, 
QPushButton#btnManageStatus, 
QPushButton#btnViewStatistics {
	background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #1e222b, stop:1 #14171e);
	color: #cbd5e1;
	font-size: 15px;
    font-weight: 600;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
	border: 1px solid #232834;
	border-radius: 16px;
	padding: 30px 25px;        
    min-width: 340px;          
	 text-align: center;       
	padding-left: 0px;
}
QPushButton#btnAddRestaurant:hover, 
QPushButton#btnManageStatus:hover, 
QPushButton#btnViewStatistics:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #252b37, stop:1 #1a1e27);
    color: #ffffff;          
    border: 1px solid #f59e0b; 
    cursor: pointer;
}


QPushButton#btnAddRestaurant:pressed, 
QPushButton#btnManageStatus:pressed, 
QPushButton#btnViewStatistics:pressed {
    background-color: #11141a;
    border: 1px solid #d97706; 
    color: #d97706;
    padding-top: 32px;        
    padding-bottom: 28px;
}

QLabel {
    color: #ffffff;            
    font-size: 14px;           
    font-weight: 600;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    qproperty-alignment: 'AlignLeft | AlignVCenter'; 
}

QLineEdit, QSpinBox, QTextEdit, QComboBox {
    background-color: #1e222b; 
    border: 1px solid #2d3545; 
    border-radius: 10px;       
    padding: 10px 12px;
    color: #ffffff;            
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

QLineEdit:focus, QSpinBox:focus, QTextEdit:focus, QComboBox:focus {
    border: 1px solid #f59e0b;
    background-color: #242935; 
}

QComboBox::drop-down {
    border: none;
    padding-right: 10px;
}
QComboBox QAbstractItemView {
    background-color: #1e222b;
    border: 1px solid #2d3545;
    color: #ffffff;
    selection-background-color: #f59e0b; 
    selection-color: #0f1115;
}

QPushButton#btnAddRestaurant_2 {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #f59e0b, stop:1 #d97706);
    color: #0f1115;            
    font-weight: bold;
    font-size: 14px;
    border: none;
    border-radius: 12px;
    padding: 14px;
    min-width: 150px;
}
QPushButton#btnAddRestaurant_2:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #fbbf24, stop:1 #f59e0b);
    cursor: pointer;
}
QPushButton#btnBackToMenu {
    background-color: rgb(255, 5, 18);
    color: rgb(0, 0, 0);
	 font-weight: bold;
    border: 1px solid #2d3545;
    font-size: 14px;
    border-radius: 12px;
    padding: 14px;
    min-width: 100px;
}

QPushButton#btnBackToMenu:hover {
    background-color: #1e222b;
    color: #ffffff;
    border: 1px solid #cbd5e1;
    cursor: pointer;
}



QTableWidget {
    background-color: #1e222b;
    color: #ffffff;
    border: 1px solid #2d3545;
    border-radius: 8px;
    gridline-color: #2d3545; 
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    outline: none; 
}


QTableWidget::item:selected {
    background-color: #f59e0b; 
    color: #0f1115;            
    font-weight: bold;
}


QHeaderView::section {
    background-color: #14171e;
    color: #94a3b8;
    padding: 8px;
    border: none;
    border-right: 1px solid #2d3545;
    font-weight: bold;
    font-size: 13px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    text-align: left;
}


QPushButton#btnToggleStatus {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #3b82f6, stop:1 #2563eb); 
    color: #ffffff;
    font-weight: bold;
    font-size: 14px;
    border: none;
    border-radius: 12px;
    padding: 12px;
    min-width: 150px;
}

QPushButton#btnToggleStatus:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #60a5fa, stop:1 #3b82f6);
    cursor: pointer;
}


QPushButton#btnBackToMenu_2 {
    background-color: rgb(170, 0, 0);
    color: #rgb(255, 255, 255);
    border: 1px solid #2d3545;
	font-weight: bold;
    font-size: 14px;
    border-radius: 12px;
    padding: 12px;
    min-width: 100px;
}

QPushButton#btnBackToMenu_2:hover {
    background-color: #1e222b;
    color: #ffffff;
    border: 1px solid #cbd5e1;
    cursor: pointer;
}</string>
